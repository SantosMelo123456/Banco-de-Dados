-- total por venda, com id da VENDA o nome do CLIENTE e o total de vendas 
select 
	vendas.id as venda,
	clientes.nome as cliente,
	SUM (vendas.valor_total) 
from vendas
inner join clientes on vendas.cliente_id = clientes.id
group by (vendas.id, clientes.id)



-- Crie uma query que Lista pets com nome do dono;
SELECT 
    clientes.nome AS cliente,
    pets.nome AS pet
FROM pets
INNER JOIN clientes ON pets.cliente_id = clientes.id



-- Criar uma querry que mostra PRODUTOS mais caros que a média / AVG calcula média
SELECT 
	produtos.nome as produto,
	preco
	from produtos
where preco > (select AVG (preco) from produtos)
INNER join preco on preco.produto_id = produto.id







