-- Procedure para transferir pet
CREATE OR REPLACE PROCEDURE transferir_pet( p_pet_id INTEGER, p_cliente_novo_id INTEGER)
LANGUAGE plpgsql
AS $$
DECLARE
    v_cliente_atual_id INTEGER;
BEGIN
    IF NOT EXISTS (SELECT 1 FROM pets WHERE id = p_pet_id) THEN
        RAISE EXCEPTION 'Pet ID=% não encontrado.', p_pet_id;
    END IF;

    IF NOT EXISTS (SELECT 1 FROM clientes WHERE id = p_cliente_novo_id) THEN
        RAISE EXCEPTION 'Cliente ID=% não encontrado.', p_cliente_novo_id;
    END IF;

    SELECT cliente_id INTO v_cliente_atual_id FROM pets WHERE id = p_pet_id;

    IF v_cliente_atual_id = p_cliente_novo_id THEN
        RAISE EXCEPTION 'O pet ID=% já pertence ao cliente ID=%.', p_pet_id, p_cliente_novo_id;
    END IF;

    UPDATE pets
    SET cliente_id = p_cliente_novo_id
    WHERE id = p_pet_id;

    RAISE NOTICE 'Pet ID=% transferido do cliente ID=% para o cliente ID=%.',
        p_pet_id, v_cliente_atual_id, p_cliente_novo_id;
END;
$$;

-- Essa PROCEDURE realiza a transferencia de um Pet:
-- 1°: declara o valor do ID DO cliente atual como inteiro
-- 2°: aplica uma condição de que existência do id Pet - tabela PET
-- 3°: aplica uma condição de existência id do novo cliente pet - tabela CLIENTE com FK em Pets
-- 4°: Aí, seleciona id do cliente atual EM valor do id do cliente Atual da tabela Pets onde o id é igual ao id do Pet - confirmação
-- 5°: Condição SE o valor do id do cliente atual for igualao do cliente novo pet, ele avisa que é há uma redudancia
-- 6°: Se não for igual, ele dá um update - atualiza - dando um set no cliente id sendo igual ao id do novo cliente pet id 
-- 7°: onde o id seja igual ao id do pet, claro
-- 8°: Dessa forma, ele joga um aviso da certificação da transferência, rebendo como parâmetro o id Pet, Valor do cliente antigo - atual - e o Id do Novo Cliente


