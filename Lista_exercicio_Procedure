CREATE OR REPLACE PROCEDURE cadastrar_agendamento(p_pet_id INTEGER, p_servico_id numeric,p_data_agendamento DATE)
LANGUAGE plpgsql
AS $$
begin
    IF NOT EXISTS (SELECT 1 FROM pet WHERE id = p_pet_id) THEN
        RAISE EXCEPTION 'Pet ID=% não encontrado.', p_pet_id;
    END IF;

    IF NOT EXISTS (SELECT 1 FROM servico WHERE id = p_servico_id) THEN
        RAISE EXCEPTION 'Serviço ID=% não encontrado.', p_servico_id;
    END IF;

    IF p_data_agendamento < CURRENT_DATE THEN
        RAISE EXCEPTION 'Data inválida: % é anterior à data atual (%).', p_data_agendamento, CURRENT_DATE;
    END IF;

    INSERT INTO agendamentos (pet_id, servico_id, data_agendamento)
    VALUES (p_pet_id, p_servico_id, p_data_agendamento);

    RAISE NOTICE 'Agendamento cadastrado com sucesso! Pet ID=%, Serviço ID=%, Data=%',
        p_pet_id, p_servico_id, p_data_agendamento;
END;
$$;
end

-- Essa PROCEDURE realiza o cadastro de um agendamento:
-- 1° - ela recebe em seu parâmetro o Id do Pet, Id do serviço, data de agendamento - tudo da tabela PET 
-- 2° - faz uma conditional statement to check if a specific pet is missing from the database, se não for encontrado ele joga um aviso e seu id
-- 3° - Mesma condição aplicada para servicos - verificação de existência
-- 4° - Se a data de agendamento Pet for menor que a data Atual ele joga um aviso
-- 5° - Aí então, se a condição for aceita, insere em Agendamentos o: id pet, id servico e a data de agendamento
-- 6° - Joga um aviso com esses 3 parâmentros inseridos, e por fim o cadastro aí é concluído:
--  Cadastro agendamento = Id Pet, Id servico x, data do agendamento


