-- Procedure para aplicar desconto
CREATE OR REPLACE PROCEDURE aplicar_desconto(p_id INTEGER, p_desconto NUMERIC)
LANGUAGE plpgsql
AS $$
DECLARE
    v_preco_atual NUMERIC(10, 2);
    v_preco_novo  NUMERIC(10, 2);
BEGIN
  IF NOT EXISTS (SELECT 1 from produto where id= p_id) THEN
  RAISE EXCEPTiON 'Produto ID=%   não encontrado', p_id;
END IF;

 if p_desconto < 1 OR p_desconto > 100 THEN
        RAISE EXCEPTION 'Percentual de desconto inválido: %. Deve ser entre 1 e 100.', p_desconto;
    END IF;

    SELECT preco INTO v_preco_atual FROM produto WHERE id = p_id;

    v_preco_novo := v_preco_atual * (1 - p_desconto / 100);

    IF v_preco_novo < 1 THEN
        RAISE EXCEPTION 'Desconto inválido: o preço final (R$ %) ficaria abaixo de R$ 1,00.', v_preco_novo;
    END IF;
    
    UPDATE produto
    SET preco = v_preco_novo
    WHERE id = p_id;

    RAISE NOTICE 'Desconto de % aplicado! Preço anterior: R$ % → Novo preço: R$ %',
        p_desconto, v_preco_atual, v_preco_novo;
END;
$$;

-- Essa PROCEDURE realiza a aplicação de desconto. Com regras de que é até 10 dígitos com 2 casas decimais.
-- 1° regra: a procedure aplicar_desconto começa captando o id do produto válido/existente
-- 2° regra: a partir daí, ela impõe uma regra de aplicação de desconto, sendo válido maior que 1 e menor que 100
-- 3° regra: Aí, a chama-se a função, faz um select do preço atual onde o seu id é igual a id do produto
-- 4° regra: Aí, se o valor do preço novo for menor que 1, não vai ser possível aplicar o desconto
-- 5° regra: atualiza o valor do produto com o valor de seu preço novo - certificação de seu id com o mesmo id do produto - e  o desconto é aplicado
-- 6° fim: desconto aplicado para produtos que entram na regra: demonstra valor do desconto, valor atual do produto e o valor do preço novo que foi atualizado


