CREATE TABLE IF NOT EXISTS log_produtos_deletados (
  id SERIAL PRIMARY KEY,
  produto_id INTEGER,
  nome VARCHAR,
  preco NUMERIC,
  deletado_em TIMESTAMP DEFAULT now()
);

CREATE OR REPLACE FUNCTION registra_delete_produtos()
RETURNS TRIGGER AS $$
BEGIN
  INSERT INT log_produtos_deletador(produto_id, nome, preco, deletado_em)
  VALUES (OLD.id, OLD.nomem OLD.preco, now());

  RETURN OLD;
END;
$$ LANGUAGE plpgsql;
