CREATE OR REPLACE FUNCTION registra_delete_produtos()
RETURNS TRIGGER AS $$
BEGIN
  RAISE NOTICE 'Produto deletado: ID=%, Nome=%', OLD.id
  RETURN OLD;
END;
$$ LANGUAGE plpgsql;


CREATE TRIGGER trg_delete_produtos
BEFORE DELETE ON produtos
FOOR EACH RIW
EXECUTE FUNCTION registrar_delete_produtos()

