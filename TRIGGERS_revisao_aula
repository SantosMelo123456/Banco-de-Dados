CREATE OR REPLACE FUNCTION atualiza_data_hora()
RETURNS TRIGGER AS $$
BEGIN
  NEW.atualizado_em:= now();
  RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_atualiza_clientes
BEFORE UPDATE ON clientes
FOR EACH ROW
EXECUTE FUNCTION atualiza_data_hora();

