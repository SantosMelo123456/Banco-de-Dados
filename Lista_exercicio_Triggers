-- Trigger de Impedir cancelamento de Agendamento concluído anteriormente
CREATE OR REPLACE FUNCTION impedir_cancelamento()
RETURNS TRIGGER AS $$
BEGIN
IF OLD.status = 'Concluído' THEN
  RAISE EXCEPTION 'Não é possível cancelar ou alterar um agendamento que já foi concluído: ID=% ', OLD.id;
END IF;

-- Mas se o status não for CONCLUÍDO, a operação segue: deleta/cancela e volta para old. Mas se for um uptade/atualização retorna New
IF trg_op = 'DELETE' THEN
        RETURN OLD;
    ELSE
        RETURN NEW;
    END IF;
END;
$$ LANGUAGE plpgsql;


CREATE TRIGGER trg_impedir_cancelamento_concluido
BEFORE UPDATE or delete ON Agendamentos
FOR EACH ROW
EXECUTE FUNCTION impedir_cancelamento_concluido();

