-- Trigger de Registrar transferncia de Pet
CREATE OR REPLACE FUNCTION log_registra_transferencia_pet()
RETURNS TRIGGER AS $$
BEGIN
	IF OLD.cliente_id <> NEW.cliente_id THEN
		INSERT INTO log_transferencias_pets (pet_id, cliente_anterior, cliente_novo, data_transferencia)
		VALUES (OLD.id, OLD.cliente_id, NEW.cliente_id, NOW());
end if;
return new;
END;
$$ LANGUAGE plpgsql;


CREATE TRIGGER trg_log_registra_transferencia_pet;
BEFORE update ON pets
FOR EACH ROW
EXECUTE FUNCTION registrar_transferencia_pet()

-- Condição principal: se o id do cliente antigo for DIFERENTE do cliente novo aí é inseridoos valores pedidos no parametro





