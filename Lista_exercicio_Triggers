-- Trigger que faz uma tabela: log_produtos deletados. Que recebe e salva parâmetros quando sempre um produto é deletado

create table if not exists log_produtos_deletados (
	id serial primary key,
	produto_id int,
	nome varchar,
	preco numeric
);

create or replace function log_produtos_deletados()
returns trigger as $$
begin
	INSERT INTO log_produtos_deletados(produto_id, nome, preco)
	values (old.id, old.nome, old.preco);
	RAISE NOTICE 'Produto deletado: Id=%, Nome=%', OLD.id, OLD.nome;

	return old;
end;
$$ LANGUAGE plpgsql;


